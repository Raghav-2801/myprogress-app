# Frontend Configuration
# Copy this file to .env and fill in your values for production

# API Base URL (leave empty to use defaults: localhost:8000 for dev, render for prod)
VITE_API_URL=https://myprogress-api.onrender.com/api

# Base path for subdirectory deployment (e.g., /myprogress)
VITE_BASE_PATH=/myprogress/
